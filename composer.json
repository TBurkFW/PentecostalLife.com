{
    "name": "faithworks/template",
    "type": "project",
    "require": {
        "composer/installers": "^2.2",
        "johnpbloch/wordpress": "^6.3.0",
        "humanmade/s3-uploads": "3.0.11",
        "wpackagist-plugin/wp-super-cache":"3.0.2",
        "wpackagist-plugin/elementor":"3.32.5",
        "wpackagist-plugin/woocommerce":"^10.7.0",
        "wpackagist-plugin/woocommerce-gateway-stripe":"9.9.2",
        "wpackagist-plugin/woocommerce-product-price-based-on-countries":"4.0.11",
        "wpackagist-plugin/mailchimp-for-woocommerce":"5.6",
        "wpackagist-plugin/essential-addons-for-elementor-lite":"6.4.0",
        "wpackagist-plugin/google-site-kit":"1.164.0",
        "wpackagist-plugin/jetpack":"14.9.1",
        "wpackagist-plugin/pods":"3.3.4",
        "wpackagist-plugin/wordpress-seo":"25.9",
        "wpackagist-plugin/better-search-replace":"1.4.10",
        "wpackagist-theme/hello-elementor":"3.4.5",
        "wpackagist-plugin/wp-smushit":"3.22.1",
        "wpackagist-plugin/redirection":"5.5.2",
        "wpackagist-plugin/code-snippets":"3.8.1",
        "wpackagist-plugin/wp-all-export":"1.4.13",
        "wpackagist-plugin/wp-all-import":"3.9.6",
        "wpackagist-plugin/safe-svg":"2.4.0"
    },
    "autoload": {
        "psr-4": {
            "Faithworks\\Boilerplate\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "johnpbloch/wordpress-core-installer": true
        },
         "platform": {
            "php": "8.3.99"
        }
    },
    "extra": {
        "installer-paths": {
            "public/app/plugins/{$name}/": ["type:wordpress-plugin"],
            "public/app/mu-plugins/{$name}/": ["type:wordpress-muplugin"],
            "public/app/themes/{$name}/": ["type:wordpress-theme"]
        },
        "wordpress-install-dir": {
            "johnpbloch/wordpress-core": "public/wp"
        }
    },
    "repositories":[
        {
            "type":"composer",
            "url":"https://wpackagist.org",
            "only": [
                "wpackagist-plugin/*",
                "wpackagist-theme/*"
            ]
        }
    ]
}
